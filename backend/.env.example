# База данных
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/college_db"

# JWT
JWT_SECRET="change-this-to-a-very-long-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-very-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Сервер
PORT=3000
NODE_ENV=development

# Загрузка файлов
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# Email (опционально, для восстановления пароля)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="College System <no-reply@college.kz>"

# CORS
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:8080"
